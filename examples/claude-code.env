# Claude Code -> syscode-telemetry-relay
# Source these (or add to your shell profile) on any machine running Claude Code.
# Replace RELAY_HOST with the relay's LAN IP or its Tailscale MagicDNS name,
# e.g. telemetry-relay or telemetry-relay.your-tailnet.ts.net

export CLAUDE_CODE_ENABLE_TELEMETRY=1
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT=http://RELAY_HOST:4317

export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp
export OTEL_TRACES_EXPORTER=otlp

# Optional: richer logs (can include prompt/tool content — review before enabling)
# export OTEL_LOG_USER_PROMPTS=1
# export OTEL_LOG_TOOL_DETAILS=1

# Traces (beta). Traces use the OTLP/HTTP endpoint on :4318.
export CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
export BETA_TRACING_ENDPOINT=http://RELAY_HOST:4318

# Optional: faster export while testing (milliseconds)
# export OTEL_METRIC_EXPORT_INTERVAL=10000
# export OTEL_LOGS_EXPORT_INTERVAL=10000
