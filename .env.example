# Grafana Cloud OTLP endpoint (Connections > OTLP in your Grafana Cloud stack).
# Include the /otlp suffix; do NOT add /v1/metrics etc.
GC_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp

# Grafana Cloud instance/stack ID (the numeric "Instance ID" / username).
GC_INSTANCE_ID=123456

# Grafana Cloud API token / Cloud Access Policy token (used as the password).
GC_API_TOKEN=glc_xxxxxxxxxxxxxxxxxxxxxxxx

# Tailscale auth key (Settings > Keys in the Tailscale admin console).
# Use a reusable, optionally ephemeral, key.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
TS_HOSTNAME=telemetry-relay

# LAN interface to publish the OTLP ports on. 0.0.0.0 = all interfaces,
# or set a specific host IP (e.g. 10.0.0.5) to restrict to one LAN network.
LAN_BIND_IP=0.0.0.0
