{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "version": 1,
  "title": "Claude Code — Usage & Cost",
  "uid": "claude-code-usage",
  "tags": ["claude-code", "telemetry"],
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values({__name__=~\"claude_code_token_usage.*\"}, model)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total cost (range)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } },
      "targets": [
        { "refId": "A", "expr": "sum(increase({__name__=~\"claude_code_cost_usage.*\", model=~\"$model\"}[$__range]))" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total tokens (range)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "sum(increase({__name__=~\"claude_code_token_usage.*\", model=~\"$model\"}[$__range]))" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sessions started (range)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "sum(increase({__name__=~\"claude_code_session_count.*\"}[$__range]))" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Relay heartbeat",
      "description": "Deadman canary: green = the relay is forwarding to Grafana Cloud. No data = forwarding stopped.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "special", "options": { "match": "null", "result": { "text": "NO DATA", "color": "red" } } }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "max(alloy_build_info)", "legendFormat": "alloy" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cost over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        { "refId": "A", "expr": "sum(increase({__name__=~\"claude_code_cost_usage.*\", model=~\"$model\"}[$__interval]))", "legendFormat": "cost" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tokens by type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "sum by (type) (rate({__name__=~\"claude_code_token_usage.*\", model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Tokens by model (range)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (model) (increase({__name__=~\"claude_code_token_usage.*\"}[$__range]))", "format": "table", "instant": true }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Lines of code (added / removed)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "sum by (type) (increase({__name__=~\"claude_code_lines_of_code_count.*\"}[$__interval]))", "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Code-edit decisions (accept / reject)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "sum by (decision) (increase({__name__=~\"claude_code_code_edit_tool_decision.*\"}[$__interval]))", "legendFormat": "{{decision}}" }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Relay health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Points sent to Grafana Cloud (rate)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "targets": [
        { "refId": "A", "expr": "sum by (data_type) (rate(otelcol_exporter_sent_metric_points_total{exporter=~\".*grafanacloud.*\"}[$__rate_interval]))", "legendFormat": "metrics" },
        { "refId": "B", "expr": "sum(rate(otelcol_exporter_sent_log_records_total{exporter=~\".*grafanacloud.*\"}[$__rate_interval]))", "legendFormat": "logs" },
        { "refId": "C", "expr": "sum(rate(otelcol_exporter_sent_spans_total{exporter=~\".*grafanacloud.*\"}[$__rate_interval]))", "legendFormat": "spans" }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Send failures (should stay 0)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "cps", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.001 }] } } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_exporter_send_failed_metric_points_total{exporter=~\".*grafanacloud.*\"}[$__rate_interval])) + sum(rate(otelcol_exporter_send_failed_log_records_total{exporter=~\".*grafanacloud.*\"}[$__rate_interval])) + sum(rate(otelcol_exporter_send_failed_spans_total{exporter=~\".*grafanacloud.*\"}[$__rate_interval]))", "legendFormat": "failed/s" }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Exporter queue size",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "sum by (data_type) (otelcol_exporter_queue_size{exporter=~\".*grafanacloud.*\"})", "legendFormat": "{{data_type}}" }
      ]
    }
  ]
}
